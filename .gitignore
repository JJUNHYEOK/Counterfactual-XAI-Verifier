# =============================================================================
# Counterfactual-XAI-Verifier .gitignore
# =============================================================================

# ── Secrets ──────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Virtual environments ─────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── IDE / OS ─────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db
desktop.ini

# ── Generated assets (regenerated by visualizer / run scripts) ──────────────
assets/
mountain_test_output.png
*.png
*.jpg
*.jpeg
*.gif
!docs/**/*.png
!docs/**/*.jpg

# ── MATLAB / Simulink build cache ────────────────────────────────────────────
slprj/
sccprj/
*.slxc
*.mexw64
*.mexa64
*.mexmaca64
*.mex*
*.asv
*.autosave
*.slx.autosave
*.slx.r*
*.slx.original

# Optional: uncomment if you don't want to track the Simulink model itself
# (it's regenerated by build_mountain_uav_model.m)
# *.slx

# ── Workspace dumps ──────────────────────────────────────────────────────────
*.mat
!data/**/*.mat

# ── ML model weights ─────────────────────────────────────────────────────────
*.pt
*.pth
*.ckpt
*.onnx
*.h5
*.pkl
*.safetensors

# ── Run outputs (regenerated each run; keep training data committed) ─────────
data/dspy_eval_iter_*.json
data/dspy_scenario_iter_*.json
data/dspy_loop_summary.json
dspy_pipeline/compiled_program.json

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Build / dist ─────────────────────────────────────────────────────────────
build/
dist/
*.tar.gz
*.zip
